# trackly-mcp v2 — required configuration.
#
# LOCAL DEV:  `cp .env.example .env`, fill in the secrets, then run e.g.
#               uv run --env-file .env trackly-mcp
#             (.env is gitignored — never commit real secrets.)
#
# PRODUCTION (Fly): do NOT ship a .env. Set these as Fly secrets instead:
#               fly secrets set SUPABASE_URL=... SUPABASE_JWT_SECRET=... \
#                 SUPABASE_ANON_KEY=... TRACKLY_API_URL=... SERVER_BASE_URL=...
#
# config.py loads all 5 below at startup and FAILS LOUD if any is missing.

# Supabase project base URL. MUST be the SAME project the Trackly backend uses
# (see backend/.env.prd) — otherwise tokens won't verify and providers differ.
SUPABASE_URL=https://dfrtsfrrtgzccdbcrtka.supabase.co

# HS256 secret used to verify Supabase access tokens.
# MUST be the SAME value the Trackly backend uses — the MCP server forwards
# the verified token to the backend and both verify with this secret.
# Supabase dashboard → Project Settings → API → JWT Secret.  Copy the EXISTING
# value; do not invent a new one (rotating it logs out ALL users, web + MCP).
SUPABASE_JWT_SECRET=

# Supabase anon/public key, for the unauthenticated OAuth calls to Supabase.
# Supabase dashboard → Project Settings → API → Project API keys → anon public.
SUPABASE_ANON_KEY=

# The existing Trackly REST backend the tools call.
TRACKLY_API_URL=https://tracker-thealanwang.fly.dev

# Public base URL of THIS MCP server — used for redirect_uri validation and
# the OAuth discovery metadata. Must match where it's actually served.
#   prod:  https://trackly-mcp.fly.dev
#   local: http://127.0.0.1:8080
SERVER_BASE_URL=https://trackly-mcp.fly.dev

# --- Optional (have sane defaults in server.py main()) ---
# HOST=0.0.0.0
# PORT=8080
