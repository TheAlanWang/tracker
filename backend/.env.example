# Copy to .env and fill in.
# For local dev, get values from `supabase status -o env` after `supabase start`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# Comma-separated list of frontend origins allowed to call this API.
# Defaults to local Vite dev URLs when unset; in production set this to your
# deployed frontend (e.g. https://tracker.vercel.app).
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
