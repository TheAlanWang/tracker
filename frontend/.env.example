# Frontend env template.
#
# Vite picks the file based on --mode:
#   pnpm dev          → loads `.env.dev`  (local backend on :8000, local Supabase)
#   pnpm dev:prd      → loads `.env.prd`  (hosted backend, hosted Supabase)
#
# Setup:
#   cp .env.example .env.dev
#   cp .env.example .env.prd
# Then fill in values. Both files are gitignored.
#
# In Vercel, set these as Environment Variables in Project Settings —
# don't push a .env file. Vercel will inject them at build time.

# Backend API URL.
# .env.dev: http://127.0.0.1:8000
# .env.prd: https://your-railway-api.up.railway.app
VITE_API_URL=

# Supabase project URL.
# .env.dev: http://127.0.0.1:54321
# .env.prd: https://<your-ref>.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (public) key. Safe to expose in the frontend bundle.
VITE_SUPABASE_ANON_KEY=
